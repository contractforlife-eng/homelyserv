# ============================================================
# HomelyServ backend environment variables
# Copy this file to `.env` and fill in real values.
# ============================================================

# --- Database (REQUIRED) ---------------------------------------------------
# Managed MongoDB Atlas connection string. This MUST be a persistent, backed-up
# cluster. Do NOT use mongodb://localhost — local MongoDB is ephemeral and is
# why users were disappearing. The server now refuses to start without this.
#
# Get it from: MongoDB Atlas -> Database -> Connect -> Drivers
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/homelyserv?retryWrites=true&w=majority"

# --- Runtime --------------------------------------------------------------
NODE_ENV=production
PORT=5000
CLIENT_URL=https://homelyserv-nznn.vercel.app

# --- Auth -----------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string

# --- Payments (Paymob) ----------------------------------------------------
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
