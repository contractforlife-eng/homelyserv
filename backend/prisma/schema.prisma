// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  fullName      String?
  phone         String?
  age           Int?
  address       String?
  city          String?
  country       String?
  role          Role      @default(EMPLOYER)
  status        Status    @default(ACTIVE)
  profileImage  String?
  rating        Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLogin     DateTime?

  // Relations
  workerProfile WorkerProfile?
  employerProfile EmployerProfile?
  hires         Hire[]    @relation("HireWorker")
  employerHires Hire[]    @relation("HireEmployer")
  messages      Message[]
  complaints    Complaint[]
  payments      Payment[]
  savedWorkers  SavedWorker[]

  @@map("users")
}

model WorkerProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        String?
  hourlyRate      Float?
  experience      Int?
  bio             String?
  skills          String[]
  languages       String[]
  documents       Json?
  availability    Json?
  jobsCompleted   Int       @default(0)
  trustworthiness Float     @default(0)
  speed           Float     @default(0)
  accuracy        Float     @default(0)
  memberSince     DateTime  @default(now())

  @@map("worker_profiles")
}

model EmployerProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String?
  companySize     String?
  industry        String?
  bio             String?
  socialLinks     Json?
  jobsPosted      Int       @default(0)
  hiresCompleted  Int       @default(0)

  @@map("employer_profiles")
}

model Hire {
  id              String    @id @default(cuid())
  workerId        String
  worker          User      @relation("HireWorker", fields: [workerId], references: [id])
  employerId      String
  employer        User      @relation("HireEmployer", fields: [employerId], references: [id])
  jobTitle        String
  description     String?
  amount          Float
  currency        String    @default("EGP")
  status          HireStatus @default(PENDING)
  startDate       DateTime?
  endDate         DateTime?
  duration        String?
  location        String?
  paymentMethod   String?
  contractType    String?
  workSchedule    String?
  documents       Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("hires")
}

model Payment {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  hireId          String?
  hire            Hire?     @relation(fields: [hireId], references: [id])
  amount          Float
  fee             Float     @default(0)
  netAmount       Float
  currency        String    @default("EGP")
  status          PaymentStatus @default(PENDING)
  type            PaymentType @default(HIRE)
  method          String?
  description     String?
  reference       String?
  hasReceipt      Boolean   @default(false)
  failureReason   String?
  date            DateTime  @default(now())

  @@map("payments")
}

model Complaint {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  subject         String
  description     String
  images          String[]
  status          ComplaintStatus @default(PENDING)
  type            ComplaintType @default(GENERAL)
  adminResponse   String?
  rejectionReason String?
  date            DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("complaints")
}

model Message {
  id              String    @id @default(cuid())
  senderId        String
  sender          User      @relation("SenderMessages", fields: [senderId], references: [id])
  recipientId     String
  recipient       User      @relation("RecipientMessages", fields: [recipientId], references: [id])
  text            String
  status          MessageStatus @default(SENT)
  read            Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@map("messages")
}

model SavedWorker {
  id              String    @id @default(cuid())
  employerId      String
  employer        User      @relation(fields: [employerId], references: [id])
  workerId        String
  worker          User      @relation(fields: [workerId], references: [id])
  createdAt       DateTime  @default(now())

  @@unique([employerId, workerId])
  @@map("saved_workers")
}

enum Role {
  EMPLOYER
  WORKER
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum HireStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PROCESSING
}

enum PaymentType {
  HIRE
  COMMISSION
  PAYOUT
  REFUND
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum ComplaintType {
  WORKER
  EMPLOYER
  GENERAL
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}