generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WORKER
  EMPLOYER
  ADMIN
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  role             Role           @default(WORKER)
  fullName         String
  phone            String?
  city             String?
  isVerified       Boolean        @default(false)
  isSuspended      Boolean        @default(false)
  language         String         @default("en")
  createdAt        DateTime       @default(now())
  workerProfile    WorkerProfile?
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications    Notification[]
  hiresAsEmployer  Hire[]         @relation("EmployerHires")
  reviewsGiven     Review[]       @relation("ReviewsGiven")
}

model WorkerProfile {
  id              String       @id @default(uuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id])
  category        String
  experienceYears Int          @default(0)
  expectedSalary  Float        @default(0)
  availability    String       @default("available")
  workType        String       @default("full-time")
  bioAr           String?
  bioEn           String?
  skills          String[]
  profilePhotoUrl String?
  docStatus       String       @default("pending")
  ratingAvg       Float        @default(0)
  ratingCount     Int          @default(0)
  isVisible       Boolean      @default(true)
  createdAt       DateTime     @default(now())
  documents       Document[]
  experiences     Experience[]
  hires           Hire[]       @relation("WorkerHires")
  reviews         Review[]     @relation("ReviewsReceived")
}

model Document {
  id              String        @id @default(uuid())
  workerId        String
  worker          WorkerProfile @relation(fields: [workerId], references: [id])
  type            String
  url             String
  status          String        @default("pending")
  rejectionReason String?
  createdAt       DateTime      @default(now())
}

model Experience {
  id           String        @id @default(uuid())
  workerId     String
  worker       WorkerProfile @relation(fields: [workerId], references: [id])
  employerName String
  role         String
  startDate    DateTime
  endDate      DateTime?
  description  String?
  createdAt    DateTime      @default(now())
}

model Hire {
  id               String        @id @default(uuid())
  workerId         String
  worker           WorkerProfile @relation("WorkerHires", fields: [workerId], references: [id])
  employerId       String
  employer         User          @relation("EmployerHires", fields: [employerId], references: [id])
  agreedSalary     Float
  commissionAmount Float
  vatAmount        Float
  totalDue         Float
  paymentMethod    String?
  paymentReference String?
  paymentStatus    String        @default("pending")
  paymentProofUrl  String?
  startDate        DateTime?
  status           String        @default("offer_sent")
  createdAt        DateTime      @default(now())
  messages         Message[]
  reviews          Review[]
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  hireId     String?
  hire       Hire?    @relation(fields: [hireId], references: [id])
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Review {
  id         String        @id @default(uuid())
  hireId     String
  hire       Hire          @relation(fields: [hireId], references: [id])
  workerId   String
  worker     WorkerProfile @relation("ReviewsReceived", fields: [workerId], references: [id])
  employerId String
  employer   User          @relation("ReviewsGiven", fields: [employerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime      @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}