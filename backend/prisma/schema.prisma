// backend/prisma/schema.prisma - FULL FIXED VERSION WITH PAYMENT MODEL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model Document {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  workerId        String        @db.ObjectId
  type            String
  url             String
  status          String        @default("pending")
  rejectionReason String?
  createdAt       DateTime      @default(now())
  WorkerProfile   WorkerProfile @relation(fields: [workerId], references: [id])
}

model EmployerProfile {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @unique @db.ObjectId
  companyName    String?
  companyLogo    String?
  companyPhotos  String[] @default([])
  companyWebsite String?
  companySize    String?
  industry       String?
  description    String?
  address        String?
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  User           User     @relation(fields: [userId], references: [id])
}

model Experience {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  workerId      String        @db.ObjectId
  employerName  String
  role          String
  startDate     DateTime
  endDate       DateTime?
  description   String?
  createdAt     DateTime      @default(now())
  WorkerProfile WorkerProfile @relation(fields: [workerId], references: [id])
}

model Hire {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  workerId         String        @db.ObjectId
  employerId       String        @db.ObjectId
  agreedSalary     Float
  commissionAmount Float
  vatAmount        Float
  totalDue         Float
  paymentMethod    String?
  paymentReference String?
  paymentStatus    String        @default("pending")
  paymentProofUrl  String?
  startDate        DateTime?
  status           String        @default("offer_sent")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  User             User          @relation(fields: [employerId], references: [id])
  WorkerProfile    WorkerProfile @relation(fields: [workerId], references: [id])
  Message          Message[]
  Review           Review[]
  Payment          Payment[]
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId       String   @db.ObjectId
  receiverId     String   @db.ObjectId
  hireId         String?  @db.ObjectId
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  
  // CHAT SYSTEM FIELDS
  conversationId String?  @map("conversationId")
  senderName     String?  @map("senderName")
  senderRole     String?  @map("senderRole")
  recipientName  String?  @map("recipientName")
  recipientRole  String?  @map("recipientRole")
  delivered      Boolean  @default(true)
  updatedAt      DateTime @updatedAt @map("updatedAt")
  
  // Relations
  Hire                           Hire?    @relation(fields: [hireId], references: [id])
  User_Message_receiverIdToUser  User     @relation("Message_receiverIdToUser", fields: [receiverId], references: [id])
  User_Message_senderIdToUser    User     @relation("Message_senderIdToUser", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([conversationId, createdAt(sort: Asc)])
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])
}

model Payment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId @map("userId")
  workerId      String   @map("workerId")
  workerName    String   @map("workerName")
  employerId    String   @map("employerId")
  employerName  String   @map("employerName")
  amount        Float
  jobTitle      String   @map("jobTitle")
  paymentMethod String   @map("paymentMethod")
  paymentId     String?  @map("paymentId")
  status        String   @default("pending")
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  User          User     @relation(fields: [userId], references: [id])
  Hire          Hire?    @relation(fields: [hireId], references: [id])
  hireId        String?  @db.ObjectId @map("hireId")

  @@index([userId])
  @@index([workerId])
  @@index([employerId])
  @@index([status])
  @@map("payments")
}

model Review {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  hireId        String        @db.ObjectId
  workerId      String        @db.ObjectId
  employerId    String        @db.ObjectId
  rating        Int
  comment       String?
  createdAt     DateTime      @default(now())
  User          User          @relation(fields: [employerId], references: [id])
  Hire          Hire          @relation(fields: [hireId], references: [id])
  WorkerProfile WorkerProfile @relation(fields: [workerId], references: [id])
}

model User {
  id                               String           @id @default(auto()) @map("_id") @db.ObjectId
  email                            String           @unique
  password                         String
  username                         String           @unique
  role                             Role             @default(WORKER)
  fullName                         String
  phone                            String?
  city                             String?
  activationCode                   String?          
  isVerified                       Boolean          @default(false)
  isSuspended                      Boolean          @default(false)
  language                         String           @default("en")
  createdAt                        DateTime         @default(now())
  updatedAt                        DateTime         @updatedAt
  image                            String?          @default("")
  EmployerProfile                  EmployerProfile?
  Hire                             Hire[]
  Message_Message_receiverIdToUser Message[]        @relation("Message_receiverIdToUser")
  Message_Message_senderIdToUser   Message[]        @relation("Message_senderIdToUser")
  Notification                     Notification[]
  Review                           Review[]
  WorkerProfile                    WorkerProfile?
  Payment                          Payment[]
}

model WorkerProfile {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  userId          String       @unique @db.ObjectId
  category        String
  experienceYears Int          @default(0)
  expectedSalary  Float        @default(0)
  availability    String       @default("available")
  workType        String       @default("full-time")
  bioAr           String?
  bioEn           String?
  skills          String[]
  profilePhotoUrl String?
  docStatus       String       @default("pending")
  ratingAvg       Float        @default(0)
  ratingCount     Int          @default(0)
  isVisible       Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  Document        Document[]
  Experience      Experience[]
  Hire            Hire[]
  Review          Review[]
  User            User         @relation(fields: [userId], references: [id])
}

enum Role {
  WORKER
  EMPLOYER
  ADMIN
}